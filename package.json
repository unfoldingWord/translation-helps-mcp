{
  "name": "translation-helps-mcp",
  "version": "2.0.0",
  "description": "Proper MCP server for Bible translation resources from Door43 (unfoldingWord)",
  "type": "module",
  "scripts": {
    "dev": "cd web && npm run dev",
    "dev:worker": "npx wrangler dev --config wrangler.toml --port 8787",
    "dev:api": "npx wrangler dev --config wrangler.api.toml --port 8788",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:worker\" \"npm run dev\"",
    "build": "cd web && npm install && npm run build",
    "typecheck": "tsc --noEmit && cd web && npx tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=dot",
    "test:unit": "vitest run tests/unit/",
    "test:contracts": "vitest run tests/contracts/",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "deploy:api": "npx wrangler deploy --config wrangler.api.toml",
    "deploy:prod": "npm run deploy:api && npx wrangler deploy --config wrangler.toml",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "prepare": "node -e \"if (!process.env.CI) { require('child_process').execSync('husky', {stdio: 'inherit'}); }\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.1",
    "@upstash/redis": "^1.28.0",
    "agents": "^0.0.97",
    "lru-cache": "^11.5.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@cloudflare/workers-types": "^4.20260528.1",
    "@types/node": "^20.10.8",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.1.1",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tsx": "^4.20.3",
    "typescript": "^5.3.3",
    "vitest": "^3.0.0",
    "zod-to-json-schema": "^3.24.6"
  },
  "workspaces": [
    "web",
    "packages/js-sdk",
    "packages/python-sdk"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unfoldingWord/translation-helps-mcp.git"
  },
  "keywords": [
    "bible",
    "translation",
    "mcp",
    "cloudflare-workers",
    "door43",
    "article-search"
  ],
  "author": "unfoldingWord",
  "license": "MIT",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "**/*.svelte": [
      "prettier --write"
    ]
  }
}
