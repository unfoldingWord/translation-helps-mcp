# =============================================================================
# Translation Helps MCP — Dev Environment Configuration
# Copy to .env and fill in real values before running.
# NEVER commit .env to git (it is gitignored).
# =============================================================================

# --- Node environment ---
NODE_ENV=development

# --- Vector DB (dev: local Qdrant via Docker) ---
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_API_KEY=
VECTOR_DB_COLLECTION=translation-helps-development
# Must match the embedding model's output dimension.
# bge-base-en-v1.5 (Workers AI free tier) = 768
# text-embedding-3-small (OpenAI) = 1536
VECTOR_DIMENSION=768

# --- Embeddings (dev: fake; prod: workersai or openai) ---
# Options: fake | workersai | openai | local
EMBEDDINGS_PROVIDER=fake
# Must match VECTOR_DIMENSION above. Use "bert" for Workers AI bge model.
CHUNKER_TOKENIZER=bert
# Only needed when EMBEDDINGS_PROVIDER=openai
OPENAI_API_KEY=placeholder_required
# Model for OpenAI provider (alternative to Workers AI)
EMBEDDINGS_MODEL=text-embedding-3-small
# Daily token cap for cost control (10M = ~$0.20/day at small model)
EMBEDDING_DAILY_TOKEN_CAP=10000000

# --- LLM generation (dev: fake; prod: workersai or openai) ---
# Options: fake | workersai | openai | anthropic
LLM_PROVIDER=fake
LLM_MODEL=@cf/meta/llama-3.1-8b-instruct
# Only needed for openai/anthropic providers
# OPENAI_API_KEY already set above (shared)
ANTHROPIC_API_KEY=placeholder_required
# Daily request cap
LLM_DAILY_REQUEST_CAP=50000

# --- KV Store (dev: in-memory; prod: upstash redis + CF KV) ---
# Options: memory | redis | cfkv
KV_PROVIDER=memory
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
# Upstash REST API (prod free tier, 10K cmds/day)
UPSTASH_REDIS_REST_URL=placeholder_required
UPSTASH_REDIS_REST_TOKEN=placeholder_required

# --- Caching ---
BUNDLE_CACHE_MAX_SIZE=500

# --- Admin auth ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=placeholder_required

# --- Cloudflare R2 (dev: disabled; bindings used in CF Pages) ---
# Local FS fallback when R2 not available (dev only)
USE_FS_CACHE=true

# --- Cloudflare bindings (wrangler.toml injects these in CF env; set here for local wrangler dev) ---
# CF KV namespace ID for TRANSLATION_HELPS_CACHE
# CF R2 bucket name for ZIP_FILES

# --- Cloudflare Workers AI (prod only; set in wrangler.toml secrets) ---
# No env var needed locally — binding injected by wrangler
